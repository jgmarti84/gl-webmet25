# PostgreSQL Configuration
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=radardb
POSTGRES_USER=radar
POSTGRES_PASSWORD=radarpass

# Django Configuration
# Generate a new secret key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Products Directory
PRODUCTS_DIR=/data/products

# Number of open rasterio DatasetReaders cached per render thread.
# Total open file handles = TILE_RENDER_THREADS × DATASET_CACHE_SIZE_PER_THREAD
# Default: 8 threads × 32 datasets = 256 max open file handles
# DATASET_CACHE_SIZE_PER_THREAD=32

# GDAL Environment (rasterio.Env settings applied at API startup)
# GDAL_CACHEMAX — block cache size in MB (default: 256)
# GDAL_CACHEMAX=256
# VSI_CACHE — enable GDAL virtual filesystem caching (default: true)
# VSI_CACHE=true
# VSI_CACHE_SIZE — per-file VSI cache size in bytes (default: 5000000)
# VSI_CACHE_SIZE=5000000
# GDAL_DISABLE_READDIR_ON_OPEN — prevent slow directory listing on open (default: EMPTY_DIR)
# GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR

# ---------------------------------------------------------------------------
# Redis L2 tile cache
# The API maintains a two-layer tile cache:
#   L1 — in-memory LRUCache (~40 MB, per-process, fastest)
#   L2 — Redis (512 MB, shared across workers, survives restarts)
# ---------------------------------------------------------------------------
# Redis host (must match the service name in docker-compose.yml)
# REDIS_HOST=redis
# Redis port (default: 6379)
# REDIS_PORT=6379
# Redis database index (default: 0)
# REDIS_DB=0
# TTL (seconds) for tiles from past observations — these are immutable (default: 86400 = 24 h)
# REDIS_TILE_TTL_SECONDS=86400
# TTL (seconds) for tiles from recent observations — these may be updated (default: 3600 = 1 h)
# REDIS_TILE_TTL_RECENT_SECONDS=3600
# Kill-switch: set to false to disable Redis without redeploying (default: true)
# REDIS_ENABLED=true
